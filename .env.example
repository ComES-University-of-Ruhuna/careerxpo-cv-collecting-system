# ------------------------------------------------------------------------------
# CareerXpo — environment variables
# Copy this file to `.env.local` for local development or `.env` for production
# and fill in real values. Never commit the resulting file.
# ------------------------------------------------------------------------------

# --- Core ---------------------------------------------------------------------
# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/careerxpo

# Secret used to sign JWTs. Use a long, random value in production.
JWT_SECRET=your-super-secret-jwt-key-change-this

# Initial credit balance granted to new student accounts.
DEFAULT_CREDITS=100

# Public URL of the deployed web app. Used to build OAuth callback URLs and
# email links. In dev this is typically http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — used only inside email templates. Falls back to the production
# host if omitted.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Google OAuth (web sign-in) ----------------------------------------------
# The "Web application" OAuth 2.0 client from Google Cloud Console. The
# authorised redirect URI must be `<NEXT_PUBLIC_APP_URL>/api/auth/google/callback`.
GOOGLE_CLIENT_ID=your-web-oauth-client-id
GOOGLE_CLIENT_SECRET=your-web-oauth-client-secret

# --- Google OAuth (mobile app) -----------------------------------------------
# Additional client IDs shipped in the Expo app (mobile-app/app.json). The
# `/api/auth/mobile/google` endpoint accepts ID tokens minted for any of these
# audiences. Leave blank until the mobile app is deployed.
GOOGLE_MOBILE_WEB_CLIENT_ID=
GOOGLE_MOBILE_IOS_CLIENT_ID=
GOOGLE_MOBILE_ANDROID_CLIENT_ID=

# --- Google Drive (CV & bank-slip uploads) -----------------------------------
# Root Drive folder ID under which per-company CV folders and the
# `Payment_Slips` folder are auto-created.
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Drive service credentials. If unset, the app falls back to the values above
# (GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET) so a single OAuth client can serve
# both flows. Run `node scripts/get-drive-token.js` to obtain the refresh token.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=your-drive-refresh-token
# Legacy alias — either name is accepted.
GOOGLE_REFRESH_TOKEN=

# --- SMTP / email notifications ----------------------------------------------
# Used to send bid confirmations and admin notifications. Leave SMTP_HOST empty
# to disable email delivery entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Redis (optional cache) --------------------------------------------------
# When set, the student companies list is cached in Redis. Leave empty to
# fall back to an in-process cache.
REDIS_URL=

# --- Payment slip bank details (public, shown in the UI) ---------------------
# Displayed in the "Registration Fee" modal on both the web app and mobile app.
# NEXT_PUBLIC_* values are baked into the client bundle — do not put secrets
# here.
NEXT_PUBLIC_BANK_NAME=
NEXT_PUBLIC_BANK_BRANCH=
NEXT_PUBLIC_BANK_ACCOUNT_NAME=CareerXpo
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=

# --- Admin seed (scripts/seed-admin.js) --------------------------------------
# Used only by the seeding script to create the initial super-admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

